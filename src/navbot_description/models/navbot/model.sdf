<?xml version="1.0"?>
<sdf version="1.10">
  <model name="navbot">
    <link name="base_footprint">
      <pose>0 0 0 0 0 0</pose>
      <inertial>
        <mass>0.01</mass>
        <inertia>
          <ixx>0.0001</ixx>
          <iyy>0.0001</iyy>
          <izz>0.0001</izz>
        </inertia>
      </inertial>
    </link>

    <link name="base_link">
      <pose>0 0 0.08 0 0 0</pose>
      <inertial>
        <mass>4.0</mass>
        <inertia>
          <ixx>0.04</ixx>
          <iyy>0.05</iyy>
          <izz>0.07</izz>
        </inertia>
      </inertial>
      <collision name="base_collision">
        <geometry>
          <box>
            <size>0.36 0.30 0.16</size>
          </box>
        </geometry>
      </collision>
      <visual name="base_visual">
        <geometry>
          <box>
            <size>0.36 0.30 0.16</size>
          </box>
        </geometry>
        <material>
          <ambient>0.05 0.28 0.62 1.0</ambient>
          <diffuse>0.05 0.28 0.62 1.0</diffuse>
        </material>
      </visual>
    </link>

    <joint name="base_footprint_to_base_link" type="fixed">
      <parent>base_footprint</parent>
      <child>base_link</child>
    </joint>

    <link name="left_wheel">
      <pose>0 0.18 0.075 1.5708 0 0</pose>
      <inertial>
        <mass>0.4</mass>
        <inertia>
          <ixx>0.001</ixx>
          <iyy>0.001</iyy>
          <izz>0.001</izz>
        </inertia>
      </inertial>
      <collision name="left_wheel_collision">
        <geometry>
          <cylinder>
            <radius>0.075</radius>
            <length>0.045</length>
          </cylinder>
        </geometry>
      </collision>
      <visual name="left_wheel_visual">
        <geometry>
          <cylinder>
            <radius>0.075</radius>
            <length>0.045</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.04 0.04 0.04 1.0</ambient>
          <diffuse>0.04 0.04 0.04 1.0</diffuse>
        </material>
      </visual>
    </link>

    <joint name="left_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>left_wheel</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
      </axis>
    </joint>

    <link name="right_wheel">
      <pose>0 -0.18 0.075 1.5708 0 0</pose>
      <inertial>
        <mass>0.4</mass>
        <inertia>
          <ixx>0.001</ixx>
          <iyy>0.001</iyy>
          <izz>0.001</izz>
        </inertia>
      </inertial>
      <collision name="right_wheel_collision">
        <geometry>
          <cylinder>
            <radius>0.075</radius>
            <length>0.045</length>
          </cylinder>
        </geometry>
      </collision>
      <visual name="right_wheel_visual">
        <geometry>
          <cylinder>
            <radius>0.075</radius>
            <length>0.045</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.04 0.04 0.04 1.0</ambient>
          <diffuse>0.04 0.04 0.04 1.0</diffuse>
        </material>
      </visual>
    </link>

    <joint name="right_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>right_wheel</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
      </axis>
    </joint>

    <link name="front_caster">
      <pose>0.15 0 0.025 0 0 0</pose>
      <collision name="front_caster_collision">
        <geometry>
          <sphere>
            <radius>0.025</radius>
          </sphere>
        </geometry>
      </collision>
      <visual name="front_caster_visual">
        <geometry>
          <sphere>
            <radius>0.025</radius>
          </sphere>
        </geometry>
        <material>
          <ambient>0.35 0.35 0.35 1.0</ambient>
          <diffuse>0.35 0.35 0.35 1.0</diffuse>
        </material>
      </visual>
    </link>

    <joint name="front_caster_joint" type="fixed">
      <parent>base_link</parent>
      <child>front_caster</child>
    </joint>

    <link name="lidar_link">
      <pose>0.12 0 0.20 0 0 0</pose>
      <visual name="lidar_visual">
        <geometry>
          <cylinder>
            <radius>0.055</radius>
            <length>0.045</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.01 0.01 0.01 1.0</ambient>
          <diffuse>0.01 0.01 0.01 1.0</diffuse>
        </material>
      </visual>
      <sensor name="navbot_lidar" type="gpu_lidar">
        <pose>0 0 0 0 0 0</pose>
        <topic>/gz_scan</topic>
        <update_rate>10</update_rate>
        <always_on>false</always_on>
        <visualize>true</visualize>
        <lidar>
          <scan>
            <horizontal>
              <samples>720</samples>
              <resolution>1</resolution>
              <min_angle>-3.14159</min_angle>
              <max_angle>3.14159</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.12</min>
            <max>8.0</max>
            <resolution>0.01</resolution>
          </range>
        </lidar>
      </sensor>
    </link>

    <joint name="lidar_joint" type="fixed">
      <parent>base_link</parent>
      <child>lidar_link</child>
    </joint>

    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.36</wheel_separation>
      <wheel_radius>0.075</wheel_radius>
      <odom_publish_frequency>50</odom_publish_frequency>
      <topic>/cmd_vel</topic>
      <odom_topic>/odom</odom_topic>
      <tf_topic>/tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
      <max_linear_acceleration>0.8</max_linear_acceleration>
      <min_linear_acceleration>-0.8</min_linear_acceleration>
      <max_angular_acceleration>1.5</max_angular_acceleration>
      <min_angular_acceleration>-1.5</min_angular_acceleration>
    </plugin>
  </model>
</sdf>
