<?xml version="1.0"?>
<robot name="navbot">
  <link name="base_footprint"/>

  <joint name="base_footprint_to_base_link" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.08" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.36 0.30 0.16"/>
      </geometry>
      <material name="navbot_blue">
        <color rgba="0.05 0.28 0.62 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.36 0.30 0.16"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="4.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.04" ixy="0.0" ixz="0.0" iyy="0.05" iyz="0.0" izz="0.07"/>
    </inertial>
  </link>

  <joint name="left_wheel_joint" type="fixed">
    <parent link="base_link"/>
    <child link="left_wheel_link"/>
    <origin xyz="0 0.18 0" rpy="1.5708 0 0"/>
  </joint>

  <link name="left_wheel_link">
    <visual>
      <geometry>
        <cylinder radius="0.075" length="0.045"/>
      </geometry>
      <material name="wheel_dark">
        <color rgba="0.04 0.04 0.04 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="right_wheel_joint" type="fixed">
    <parent link="base_link"/>
    <child link="right_wheel_link"/>
    <origin xyz="0 -0.18 0" rpy="1.5708 0 0"/>
  </joint>

  <link name="right_wheel_link">
    <visual>
      <geometry>
        <cylinder radius="0.075" length="0.045"/>
      </geometry>
      <material name="wheel_dark"/>
    </visual>
  </link>

  <joint name="front_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_caster_link"/>
    <origin xyz="0.15 0 -0.055" rpy="0 0 0"/>
  </joint>

  <link name="front_caster_link">
    <visual>
      <geometry>
        <sphere radius="0.025"/>
      </geometry>
      <material name="caster_gray">
        <color rgba="0.35 0.35 0.35 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0.12 0 0.12" rpy="0 0 0"/>
  </joint>

  <link name="lidar_link">
    <visual>
      <geometry>
        <cylinder radius="0.055" length="0.045"/>
      </geometry>
      <material name="lidar_black">
        <color rgba="0.01 0.01 0.01 1.0"/>
      </material>
    </visual>
  </link>
</robot>

